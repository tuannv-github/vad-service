# VAD microservice — copy to vad-service/.env
# Silero tuning defaults: config/vad_defaults.json (not env)

VAD_HOST=0.0.0.0
VAD_PORT=8080
VAD_CONTAINER_NAME=vad-service
VAD_PUBLIC_PORT=8766

VAD_DEVICE=cuda
VAD_SAVE_SPEECH=false
VAD_SAVE_DIR=logs/vad

PYTORCH_IMAGE=nvcr.io/nvidia/pytorch:25.02-py3
CORS_ORIGINS=*
CUDA_VISIBLE_DEVICES=0
SHM_SIZE=8gb
# Dev: auto-reload on backend/*.py — use ./dev.sh or set VAD_RELOAD=true
VAD_RELOAD=false
VAD_RELOAD_DELAY=0.5
WATCHFILES_FORCE_POLLING=false
